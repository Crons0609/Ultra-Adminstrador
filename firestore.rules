rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: requires a signed-in request ────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    // ── Helper: safely read the caller's user document.
    //    Returns null-safe data only if the document exists.
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // ── Helper: true if the caller is a SUPER_ADMIN.
    //    Checks: (1) custom token claim, OR (2) Firestore user doc role field.
    //    The exists() check prevents null-read crashes for new users who don't
    //    yet have a document — avoiding the bootstrap deadlock.
    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'SUPER_ADMIN' ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          getUserData().role == 'SUPER_ADMIN'
        )
      );
    }

    // ── Helper: true when the caller belongs to the given company ────────────
    function belongsToCompany(companyId) {
      return isAuthenticated() && (
        request.auth.token.companyId == companyId ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          getUserData().companyId == companyId
        )
      );
    }

    // ── /users/{userId} ──────────────────────────────────────────────────────
    // Read:  any authenticated user can read any user profile.
    // Write rules (in priority order):
    //   1. A SuperAdmin can write any user document.
    //   2. An authenticated user can ALWAYS write their OWN document.
    //      This covers the critical bootstrap case where a newly-created
    //      Firebase Auth user needs to save their profile to Firestore
    //      before any role has been assigned (breaks the chicken-and-egg
    //      deadlock that existed in the previous rules).
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin()
                   || (isAuthenticated() && request.auth.uid == userId);
    }

    // ── /companies/{companyId} ───────────────────────────────────────────────
    // Read:  authenticated users who belong to this company OR SuperAdmins.
    // Write: SuperAdmins only (company config is managed by the platform).
    match /companies/{companyId} {
      allow read: if isAuthenticated() && (belongsToCompany(companyId) || isSuperAdmin());
      allow write: if isSuperAdmin();

      // Sub-collections (multi-tenant isolation).
      // Members of the company or SuperAdmins can read/write operational data.
      match /{document=**} {
        allow read, write: if isAuthenticated() && (belongsToCompany(companyId) || isSuperAdmin());
      }
    }

    // ── /superadmin/* ────────────────────────────────────────────────────────
    // Restricted exclusively to SuperAdmins.
    match /superadmin/{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
